# Copy this file to .env and fill in your values

PORT=5000

# Your MongoDB Atlas connection string (free tier). Get this from
# cloud.mongodb.com -> Database -> Connect -> Drivers, after creating a free
# M0 cluster and a database user. It looks like:
# mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/parking?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/parking?retryWrites=true&w=majority

# Any long random string, used to sign login tokens
JWT_SECRET=change_this_to_a_long_random_string

# Allowed origin for the frontend (Vite dev server default)
CLIENT_ORIGIN=http://localhost:5173

# The ONE email address that gets admin access (a dashboard of all users,
# listings, and bookings, at /admin in the app). Register or log in with
# this exact email to get admin rights. Leave blank to disable admin access
# entirely. No password sharing needed -- just use this email for your own
# normal account.
ADMIN_EMAIL=you@example.com

# Optional: powers the AI parking assistant chat widget. Get a free key from
# console.groq.com -> API Keys. Groq's free tier is generous and fast, good
# fit for a hackathon/demo. Leave this blank and the assistant widget will
# just tell people it's not set up yet; everything else in the app works
# fine without it.
GROQ_API_KEY=
