# Copy this file to .env and fill in your values

# Your backend API URL. For local development, this points at your
# separately-running backend. If you deploy the frontend and backend
# TOGETHER as one combined service (see the README's deployment section),
# leave this blank instead -- the app will then call the API on the same
# origin it's served from, with no separate URL needed.
VITE_API_URL=http://localhost:5000

# No map API key needed. Maps use OpenStreetMap tiles and the free OSRM
# routing service, both key-free. If you later switch to Google Maps for
# nicer styling/Places autocomplete, that's a swap inside
# src/components/MapView.jsx and src/components/DirectionsPanel.jsx only.
